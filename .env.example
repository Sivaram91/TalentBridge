# Operator configuration — copy this to .env and fill in values
# .env is gitignored and never committed

# AI provider: groq | gemini | ollama (default: groq)
AI_PROVIDER=groq

# Model to use — leave blank to use the provider default
#   groq default:   llama-3.3-70b-versatile
#   gemini default: gemini-2.0-flash
#   ollama default: llama3.2
AI_MODEL=

# API keys — only the key for the chosen provider is required
GROQ_API_KEY=gsk_...your_key_here
GEMINI_API_KEY=AIza...your_key_here

# Populated by the user via the Alerts screen in the dashboard
REPORT_RECIPIENT=
